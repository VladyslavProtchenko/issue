    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
